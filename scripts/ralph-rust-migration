#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
MANIFEST="$REPO_ROOT/tools/ralph-loop/tasks/byedpi-rust-migration.tsv"

usage() {
  cat <<'USAGE'
Usage:
  scripts/ralph-rust-migration list
  scripts/ralph-rust-migration dry-run all [--backend codex] [--workflow builtin:feature] [--auto-merge]
  scripts/ralph-rust-migration dry-run phase <n> [--backend codex] [--workflow builtin:feature] [--auto-merge]
  scripts/ralph-rust-migration dry-run task <id> [--backend codex] [--workflow builtin:feature] [--auto-merge]
  scripts/ralph-rust-migration start all [--backend codex] [--workflow builtin:feature] [--auto-merge]
  scripts/ralph-rust-migration start phase <n> [--backend codex] [--workflow builtin:feature] [--auto-merge]
  scripts/ralph-rust-migration start task <id> [--backend codex] [--workflow builtin:feature] [--auto-merge]

Defaults:
  backend      codex
  workflow     builtin:feature
  merge mode   manual (--no-auto-merge)
USAGE
}

fail() {
  echo "Error: $*" >&2
  exit 1
}

read_manifest() {
  [[ -f "$MANIFEST" ]] || fail "Missing manifest: $MANIFEST"
}

list_tasks() {
  read_manifest
  printf "%-5s %-32s %-14s %s\n" "Phase" "Task ID" "Iterations" "Description"
  printf "%-5s %-32s %-14s %s\n" "-----" "--------------------------------" "--------------" "-----------"
  while IFS=$'\t' read -r phase id slug max_iterations task_file description; do
    [[ -z "$phase" || "${phase#\#}" != "$phase" ]] && continue
    printf "%-5s %-32s %-14s %s\n" "$phase" "$id" "$max_iterations" "$description"
  done < "$MANIFEST"
}

collect_tasks() {
  local selection_type="$1"
  local selection_value="${2:-}"

  while IFS=$'\t' read -r phase id slug max_iterations task_file description; do
    [[ -z "$phase" || "${phase#\#}" != "$phase" ]] && continue
    case "$selection_type" in
      all)
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$phase" "$id" "$slug" "$max_iterations" "$task_file" "$description"
        ;;
      phase)
        [[ "$phase" == "$selection_value" ]] || continue
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$phase" "$id" "$slug" "$max_iterations" "$task_file" "$description"
        ;;
      task)
        [[ "$id" == "$selection_value" ]] || continue
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$phase" "$id" "$slug" "$max_iterations" "$task_file" "$description"
        ;;
      *)
        fail "Unknown selection type: $selection_type"
        ;;
    esac
  done < "$MANIFEST"
}

launch_tasks() {
  local mode="$1"
  local selection_type="$2"
  local selection_value="$3"
  local backend="$4"
  local workflow="$5"
  local auto_merge="$6"
  local launched=0

  while IFS=$'\t' read -r phase id slug max_iterations task_file description; do
    [[ -n "$phase" ]] || continue
    launched=1
    echo "[$mode] phase $phase :: $id"
    echo "  $description"
    local cmd=(
      "$REPO_ROOT/scripts/ralph-loop"
      start
      --backend "$backend"
      --task-file "$task_file"
      --slug "$slug"
      --workflow "$workflow"
      --max-iterations "$max_iterations"
    )
    if [[ "$mode" == "dry-run" ]]; then
      cmd+=(--dry-run)
    fi
    if [[ "$auto_merge" != "1" ]]; then
      cmd+=(--no-auto-merge)
    fi
    "${cmd[@]}"
    echo
  done < <(collect_tasks "$selection_type" "$selection_value")

  [[ "$launched" == "1" ]] || fail "No tasks matched selection"
}

main() {
  read_manifest
  [[ $# -gt 0 ]] || {
    usage
    exit 1
  }

  case "$1" in
    list)
      [[ $# -eq 1 ]] || fail "list does not accept extra arguments"
      list_tasks
      exit 0
      ;;
    start|dry-run)
      local mode="$1"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "Unknown command: $1"
      ;;
  esac

  [[ $# -gt 0 ]] || fail "Missing selection: all | phase <n> | task <id>"

  local selection_type="$1"
  local selection_value=""
  local backend="codex"
  local workflow="builtin:feature"
  local auto_merge="0"

  case "$selection_type" in
    all)
      shift
      ;;
    phase|task)
      [[ $# -ge 2 ]] || fail "$selection_type requires a value"
      selection_value="$2"
      shift 2
      ;;
    *)
      fail "Selection must be: all | phase <n> | task <id>"
      ;;
  esac

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --backend)
        [[ $# -ge 2 ]] || fail "--backend requires a value"
        backend="$2"
        shift 2
        ;;
      --workflow)
        [[ $# -ge 2 ]] || fail "--workflow requires a value"
        workflow="$2"
        shift 2
        ;;
      --auto-merge)
        auto_merge="1"
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        fail "Unknown option: $1"
        ;;
    esac
  done

  case "$backend" in
    claude|codex) ;;
    *) fail "--backend must be either 'claude' or 'codex'" ;;
  esac

  launch_tasks "$mode" "$selection_type" "$selection_value" "$backend" "$workflow" "$auto_merge"
}

main "$@"
